<idea-plugin>
<!--  <depends>com.android.tools.gradle.dsl</depends>-->
  <extensionPoints>
    <extensionPoint qualifiedName="com.android.tools.idea.gradle.dsl.gradleDeclarativeBuildModelProvider"
                    interface="com.android.tools.idea.gradle.dsl.model.GradleDeclarativeBuildModelProvider"
                    dynamic="true" />
    <extensionPoint qualifiedName="com.android.tools.idea.gradle.dsl.gradleDeclarativeSettingsModelProvider"
                    interface="com.android.tools.idea.gradle.dsl.model.GradleDeclarativeSettingsModelProvider"
                    dynamic="true" />
  </extensionPoints>

  <extensions defaultExtensionNs="com.android.tools.idea.gradle.dsl">
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.model.crashlytics.CrashlyticsBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.model.crashlytics.FirebaseCrashlyticsBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.model.android.AndroidBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.model.android.AndroidDeclarativeBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.model.android.AndroidDefaultDslModelBlockProvider"/>
    <gradleDeclarativeBuildModelProvider implementation="com.android.tools.idea.gradle.dsl.model.android.AndroidGradleDeclarativeBuildModelProvider"/>
    <gradleDeclarativeSettingsModelProvider implementation="com.android.tools.idea.gradle.dsl.model.android.AndroidGradleDeclarativeSettingsModelProvider"/>
  </extensions>
</idea-plugin>