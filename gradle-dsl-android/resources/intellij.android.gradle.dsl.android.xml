<idea-plugin package="com.android.tools.idea.gradle.dsl.android" visibility="internal">
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <!-- JetBrains patch: com.android.tools.gradle.dsl is not relevant for IJ -->
    <plugin id="org.jetbrains.idea.gradle.dsl"/>
  </dependencies>
  <!-- endregion -->
<!--  <depends>com.android.tools.gradle.dsl</depends>-->
  <extensionPoints>
    <extensionPoint qualifiedName="com.android.tools.idea.gradle.dsl.gradleDeclarativeBuildModelProvider"
                    interface="com.android.tools.idea.gradle.dsl.model.GradleDeclarativeBuildModelProvider"
                    dynamic="true" />
    <extensionPoint qualifiedName="com.android.tools.idea.gradle.dsl.gradleDeclarativeSettingsModelProvider"
                    interface="com.android.tools.idea.gradle.dsl.model.GradleDeclarativeSettingsModelProvider"
                    dynamic="true" />
  </extensionPoints>

  <extensions defaultExtensionNs="com.android.tools.idea.gradle.dsl">
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.android.model.crashlytics.CrashlyticsBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.android.model.crashlytics.FirebaseCrashlyticsBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.android.model.android.AndroidBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.android.model.android.AndroidDeclarativeBlockModelProvider"/>
    <blockModelProvider implementation="com.android.tools.idea.gradle.dsl.android.model.android.AndroidDefaultDslModelBlockProvider"/>
    <gradleDeclarativeBuildModelProvider implementation="com.android.tools.idea.gradle.dsl.android.model.android.AndroidGradleDeclarativeBuildModelProvider"/>
    <gradleDeclarativeSettingsModelProvider implementation="com.android.tools.idea.gradle.dsl.android.model.android.AndroidGradleDeclarativeSettingsModelProvider"/>
  </extensions>
</idea-plugin>