<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <runConfigurationProducer implementation="com.android.screenshottest.producers.ScreenshotTestMethodGradleConfigurationProducer"/>
    <runConfigurationProducer implementation="com.android.screenshottest.producers.ScreenshotTestClassGradleConfigurationProducer"/>
    <runConfigurationProducer implementation="com.android.screenshottest.producers.ScreenshotTestAllInPackageGradleConfigurationProducer"/>
    <runConfigurationProducer implementation="com.android.screenshottest.producers.ScreenshotTestAllInDirectoryGradleConfigurationProducer"/>
    <postStartupActivity implementation="com.android.tools.idea.testartifacts.screenshot.ScreenshotTestAnalyticsProjectActivity"/>
  </extensions>
  <actions>
    <group id="Android.UpdateScreenshotReferenceImagesGroup">
      <!--
           This generic action delegates to the registered RunConfigurationProducers to determine
           the context (Method, Class, Directory), ensuring a single menu item covers all scopes
           without duplication.
      -->
      <action
          id="com.android.screenshottest.action.UpdateReferenceImagesAction"
          class="com.android.screenshottest.action.UpdateReferenceImagesAction"
          text="Add/Update Reference Images"
          description="Add/Update reference images">
      </action>
      <separator/>
      <add-to-group group-id="RunContextGroup" anchor="last"/>
    </group>
  </actions>
  <actions>
    <action id="com.android.screenshottest.action.UpdateReferenceImagesFromTestPanelAction"
            class="com.android.screenshottest.action.UpdateReferenceImagesFromTestPanelAction"
            text="Update Reference Images..."/>
  </actions>
  <extensions defaultExtensionNs="com.android.tools.idea.testartifacts.instrumented.testsuite">
    <AndroidTestSuiteActionProvider implementation="com.android.screenshottest.action.ScreenshotTestActionProvider"/>
  </extensions>
</idea-plugin>
