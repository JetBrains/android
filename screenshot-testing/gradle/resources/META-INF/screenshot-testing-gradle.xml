<idea-plugin>
  <extensions defaultExtensionNs="com.intellij">
    <postStartupActivity implementation="com.android.tools.idea.testartifacts.screenshot.ScreenshotTestAnalyticsStartupActivity"/>
  </extensions>
  <actions>
    <action
        id="com.android.screenshottest.action.UpdateReferenceImagesAction"
        class="com.android.screenshottest.action.UpdateReferenceImagesAction"
        text="Add/Update Reference Images"
        description="Add/Update reference images from gutter icon">
    </action>
    <group id="Android.UpdateScreenshotReferenceImagesGroup">
      <action
          id="com.android.screenshottest.action.UpdateReferenceImagesInClassAction"
          class="com.android.screenshottest.action.UpdateReferenceImagesInClassAction"
          text="Add/Update Reference Images"
          description="Add/Update reference images for all screenshot tests in class">
      </action>
      <action
          id="com.android.screenshottest.action.UpdateReferenceImagesInDirectoryAction"
          class="com.android.screenshottest.action.UpdateReferenceImagesInDirectoryAction"
          text="Add/Update Reference Images"
          description="Add/Update reference images for all screenshot tests in directory">
      </action>
      <separator/>
      <add-to-group group-id="RunContextGroup" anchor="last"/>
    </group>
  </actions>
  <actions>
    <action id="com.android.screenshottest.action.UpdateReferenceImagesFromTestPanelAction"
            class="com.android.screenshottest.action.UpdateReferenceImagesFromTestPanelAction"
            text="Update Reference Images..."/>
  </actions>
  <extensions defaultExtensionNs="com.android.tools.idea.testartifacts.instrumented.testsuite">
    <AndroidTestSuiteActionProvider implementation="com.android.screenshottest.action.ScreenshotTestActionProvider"/>
  </extensions>
</idea-plugin>
