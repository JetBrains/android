<idea-plugin xmlns:xi="http://www.w3.org/2001/XInclude">
  <id>com.android.tools.gradle.dsl</id>
  <name>Gradle DSL Parser Support</name>
  <description>
    <![CDATA[
    Provides support for parsing Gradle build files
    ]]>
  </description>
  <depends>com.intellij.gradle</depends>
  <depends>org.intellij.groovy</depends>
  <depends>com.intellij.java</depends>
  <depends>org.jetbrains.kotlin</depends>
  <depends>org.toml.lang</depends>

  <!-- This is temporary mechanism to mark certain plugins as K2-compatible. See IntelliJ commit cf213fb139 for details. -->
  <extensions defaultExtensionNs="org.jetbrains.kotlin">
    <!--suppress PluginXmlValidity -->
    <supportsKotlinPluginMode supportsK2="true"/>
  </extensions>

  <xi:include href="/META-INF/gradle-dsl.xml"/>
  <!--<xi:include href="/META-INF/gradle-dsl-declarative.xml"/>-->
  <xi:include href="/META-INF/gradle-dsl-flags.xml"/>
  <xi:include href="/META-INF/gradle-dsl-groovy.xml"/>
  <xi:include href="/META-INF/gradle-dsl-kotlin.xml"/>
  <xi:include href="/META-INF/gradle-dsl-toml.xml"/>
</idea-plugin>